# Local build settings. This project currently has no Maven profile.
MAVEN_PROFILE=
MAVEN_SKIP_TESTS=true
IMAGE_NAME=flyingjack-wms-cashier
IMAGE_TAG=
DOCKER_PLATFORM=
DOCKER_FILE_PATH=Dockerfile.lan

# Target container settings
CONTAINER_NAME=wms-cashier
HOST_PORT=8086
CONTAINER_PORT=8086
MANAGEMENT_HOST_PORT=8081
MANAGEMENT_CONTAINER_PORT=8081
RESTART_POLICY=unless-stopped
DOCKER_NETWORK=
HEALTHCHECK_URL=http://127.0.0.1:8081/actuator/health
HEALTHCHECK_RETRIES=30
HEALTHCHECK_INTERVAL=2

# SSH/SCP target settings (SSH key authentication is recommended)
DEPLOY_HOST=192.168.31.100
DEPLOY_USER=deploy
DEPLOY_SSH_PORT=22
DEPLOY_REMOTE_DIR=/tmp/wms-cashier-lan
DEPLOY_KEEP_BUNDLE=false
BUNDLE_PATH=

# Lines below this point are passed to the Spring Boot container.
SPRING_PROFILES_ACTIVE=dev
DB_URL=jdbc:postgresql://192.168.31.162:5432/wms_cashier
DB_USERNAME=postgres
DB_PASSWORD=postgres
REDIS_HOST=192.168.31.162
REDIS_PORT=6379
REDIS_PASSWORD=
AUTH_ISSUER_URI=http://192.168.31.100:9001
# Overrides the dev profile's localhost auth-service Feign URL in the container.
SPRING_APPLICATION_JSON='{"spring":{"cloud":{"openfeign":{"client":{"config":{"auth-service":{"url":"http://192.168.31.100:9001"}}}}}}}'
